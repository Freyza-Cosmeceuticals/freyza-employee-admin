{
  "useTabs": false,
  "singleQuote": false,
  "trailingComma": "none",
  "semi": false,
  "svelteIndentScriptAndStyle": false,
  "bracketSameLine": true,
  "printWidth": 100,
  "plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
  "tailwindStylesheet": "./src/app.css",
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte"
      }
    }
  ]
}
