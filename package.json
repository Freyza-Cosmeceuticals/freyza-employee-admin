{
  "name": "freyza-employee-admin",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:migrate": "bunx prisma generate && env $(cat .env.local) bunx prisma migrate dev",
    "db:migrate-create": "bunx prisma generate && env $(cat .env.local) bunx prisma migrate dev --create-only"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.548.0",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.48.3",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.16",
    "@types/bun": "^1.3.1",
    "@types/node": "^24.9.2",
    "bits-ui": "^2.14.1",
    "clsx": "^2.1.1",
    "formsnap": "^2.0.1",
    "prisma": "^6.18.0",
    "svelte": "^5.43.0",
    "svelte-check": "^4.3.3",
    "svelte-sonner": "^1.0.5",
    "sveltekit-superforms": "^2.28.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "tailwindcss": "^4.1.16",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.77.0",
    "mode-watcher": "^1.1.0",
    "zod": "^4.1.12",
    "zod-form-data": "^3.0.1"
  }
}
