{
  "name": "freyza-employee-admin",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:generate": "bun --env-file=.env.local prisma generate",
    "db:migrate": "bun run db:generate && bun --env-file=.env.local prisma migrate dev",
    "db:migrate-create": "bun run db:generate && bun --env-file=.env.local prisma migrate dev --create-only"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.556.0",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@types/bun": "^1.3.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.1",
    "bits-ui": "^2.14.4",
    "clsx": "^2.1.1",
    "formsnap": "^2.0.1",
    "prisma": "^7.1.0",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "svelte-sonner": "^1.0.7",
    "sveltekit-superforms": "^2.28.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.86.2",
    "luxon": "^3.7.2",
    "mode-watcher": "^1.1.0",
    "zod": "^4.1.13",
    "zod-form-data": "^3.0.1"
  }
}
